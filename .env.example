# Django
# SECRET_KEY: required when DEBUG=false (production). Optional in local dev:
# if unset or empty, an insecure `django-insecure-dev-only-...` fallback is
# used and a RuntimeWarning is logged. Generate a strong key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# DEBUG: truthy values (case-insensitive) are `1`, `true`, `yes`.
# Anything else (`0`, `false`, `no`, empty) is falsy. Default: true.
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# SITE_BASE_URL: canonical base URL used to build absolute links
# (unsubscribe, calendar invites, password resets, share URLs, OG /
# canonical meta tags, OAuth redirect URIs, Slack announcements,
# UTM destinations). Set this per environment:
#   - local dev:  http://localhost:8000
#   - staging:    https://dev.aishippinglabs.com
#   - production: https://aishippinglabs.com
# Studio shows an amber warning banner when this disagrees with the
# request host so dev sends never ship the prod hostname by accident.
SITE_BASE_URL=http://localhost:8000

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth (login)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# GitHub App (content sync from private repos)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Slack
# SLACK_ENABLED must be explicitly 'true' to send messages — off by default
# so dev/test environments never post to real Slack channels.
SLACK_ENABLED=false
SLACK_ENVIRONMENT=development
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
SLACK_BOT_TOKEN=
SLACK_COMMUNITY_CHANNEL_IDS=
SLACK_DEV_COMMUNITY_CHANNEL_IDS=
SLACK_TEST_COMMUNITY_CHANNEL_IDS=
SLACK_INVITE_URL=
SLACK_ANNOUNCEMENTS_CHANNEL_ID=
SLACK_DEV_ANNOUNCEMENTS_CHANNEL_ID=
SLACK_TEST_ANNOUNCEMENTS_CHANNEL_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Zoom
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_WEBHOOK_SECRET_TOKEN=

# AWS (SES + S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1
AWS_S3_RECORDINGS_BUCKET=
AWS_S3_RECORDINGS_REGION=eu-central-1
SES_FROM_EMAIL=community@aishippinglabs.com

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Content CDN
CONTENT_CDN_BASE=/static/content-images
