              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "description": "A working eval harness"
              },
              "schema": {
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "done": {
                    "type": "boolean"
                  },
                  "position": {
                    "minimum": 0,
                    "type": "integer"
                  }
                },
                "required": [
                  "description"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created deliverable."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing key or missing ``plans:write`` scope."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Plan not found for this member."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Validation error."
          }
        },
        "summary": "Create a deliverable",
        "tags": [
          "Plans"
        ]
      }
    },
