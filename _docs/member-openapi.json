{
  "components": {
    "schemas": {
      "ErrorResponse": {
        "properties": {
          "code": {
            "description": "Machine-readable error code",
            "type": "string"
          },
          "details": {
            "additionalProperties": true,
            "description": "Optional per-field error details",
            "type": "object"
          },
          "error": {
            "description": "Human-readable message",
            "type": "string"
          }
        },
        "required": [
          "error",
          "code"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "tokenAuth": {
        "description": "Send the header ``Authorization: Token <asl_member_...>``. Keys are member-owned, scoped to the owner's data, and cannot authenticate against the staff/operator ``/api/`` surface.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "externalDocs": {
    "description": "Member Plans API usage guide",
    "url": "https://github.com/AI-Shipping-Labs/website/blob/main/docs/member-api/plans.md"
  },
  "info": {
    "description": "Member API for AI Shipping Labs. All endpoints accept JSON in and return JSON out. Authentication is via the ``Authorization: Token <key>`` header where ``<key>`` is a member-owned API key starting with ``asl_member_``. Member keys are scoped to the owner's data; plan endpoints only return or update plans owned by that key owner.",
    "title": "AI Shipping Labs Member API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/member-api/v1/plans": {
      "get": {
        "description": "Lists plans owned by the authenticated member API key owner, newest first. Never returns other members' plans.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "plans": [
                    {
                      "created_at": "2026-05-01T10:00:00+00:00",
                      "id": 12,
                      "member": {
                        "display_name": "Alice"
                      },
                      "progress": {
                        "checkpoints_done": 1,
                        "checkpoints_total": 4
                      },
                      "shared_at": null,
                      "sprint": {
                        "name": "May 2026",
                        "slug": "may-2026"
                      },
                      "title": "Ship an eval toolkit",
                      "updated_at": "2026-05-01T10:00:00+00:00",
                      "visibility": "private"
                    }
                  ]
                }
              }
            },
            "description": "Owned plan list."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing or invalid member API key."
          }
        },
        "summary": "List owned plans",
        "tags": [
          "Plans"
        ]
      }
    },
    "/member-api/v1/plans/{plan_id}": {
      "get": {
        "description": "Returns one owned plan with member-safe nested content. Cohort visibility does not grant member API read access. Requires the ``plans:read`` scope.",
        "parameters": [
          {
            "in": "path",
            "name": "plan_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Owned nested plan detail."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing key or missing ``plans:read`` scope."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Plan not found for this member."
          }
        },
        "summary": "Get owned plan detail",
        "tags": [
          "Plans"
        ]
      },
      "patch": {
        "description": "Partially updates plan-level fields (title, goal, summary.*, focus.*, accountability, visibility). Only supplied keys change. ``visibility`` accepts ``private`` or ``cohort``; ``public`` is reserved and rejected. Requires the ``plans:write`` scope. Returns the full plan detail.",
        "parameters": [
          {
            "in": "path",
            "name": "plan_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "focus": {
                  "main": "Evaluation",
                  "supporting": [
                    "Tracing"
                  ]
                },
                "summary": {
                  "goal": "A reusable eval harness for my agent"
                },
                "title": "Ship an eval harness",
                "visibility": "cohort"
              },
              "schema": {
                "properties": {
                  "accountability": {
                    "type": "string"
                  },
                  "focus": {
                    "type": "object"
                  },
                  "goal": {
                    "maxLength": 280,
                    "type": "string"
                  },
                  "summary": {
                    "type": "object"
                  },
                  "title": {
                    "maxLength": 280,
                    "type": "string"
                  },
                  "visibility": {
                    "enum": [
                      "private",
                      "cohort"
                    ],
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated owned plan detail."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing key or missing ``plans:write`` scope."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Plan not found for this member."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Validation error; no partial writes."
          }
        },
        "summary": "Edit owned plan narrative fields",
        "tags": [
          "Plans"
        ]
      }
    },
    "/member-api/v1/plans/{plan_id}/checkpoints/{checkpoint_id}": {
      "delete": {
        "description": "Deletes an owned checkpoint. Requires ``plans:write``.",
        "parameters": [
          {
            "in": "path",
            "name": "plan_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "path",
            "name": "checkpoint_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Checkpoint deleted."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing key or missing ``plans:write`` scope."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Plan not found for this member."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Checkpoint does not belong to this plan."
          }
        },
        "summary": "Delete a checkpoint",
        "tags": [
          "Plans"
        ]
      },
      "patch": {
        "description": "Updates ``description`` / ``position`` / ``done`` on an owned checkpoint. Supplying ``week_id`` (a week of the same plan) moves it to that week. Requires ``plans:write``.",
        "parameters": [
          {
            "in": "path",
            "name": "plan_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "path",
            "name": "checkpoint_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "description": "Refine the eval rubric",
                "done": true
              },
              "schema": {
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "done": {
                    "type": "boolean"
                  },
                  "position": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "week_id": {
                    "type": "integer"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated checkpoint."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing key or missing ``plans:write`` scope."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Plan not found for this member."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Validation error or checkpoint/week not in plan."
          }
        },
        "summary": "Update or move a checkpoint",
        "tags": [
          "Plans"
        ]
      }
    },
    "/member-api/v1/plans/{plan_id}/deliverables": {
      "post": {
        "description": "Adds a plan-level deliverable. ``description`` is required. Requires ``plans:write``.",
        "parameters": [
