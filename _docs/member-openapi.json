              },
              "schema": {
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "done": {
                    "type": "boolean"
                  },
                  "position": {
                    "minimum": 0,
                    "type": "integer"
                  }
                },
                "type": "object"
              }
