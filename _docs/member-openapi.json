    "/member-api/v1/plans/{plan_id}/next-steps": {
      "post": {
        "description": "Adds a plan-level next step. ``description`` is required. ``kind`` is ``pre_sprint`` (default) or ``next_step``. Requires ``plans:write``.",
        "parameters": [
          {
            "in": "path",
            "name": "plan_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "description": "Read the tracing docs",
                "kind": "pre_sprint"
              },
              "schema": {
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "done": {
                    "type": "boolean"
                  },
                  "kind": {
                    "enum": [
                      "pre_sprint",
                      "next_step"
                    ],
                    "type": "string"
                  },
                  "position": {
                    "minimum": 0,
                    "type": "integer"
                  }
                },
                "required": [
                  "description"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created next step."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing key or missing ``plans:write`` scope."
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Plan not found for this member."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Validation error (e.g. invalid kind)."
          }
        },
        "summary": "Create a next step",
        "tags": [
          "Plans"
        ]
      }
    },
