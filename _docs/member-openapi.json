              }
            },
            "description": "Validation error; no partial writes."
          }
        },
        "summary": "Update owned plan progress",
        "tags": [
          "Plans"
        ]
      }
    },
    "/member-api/v1/plans/{plan_id}/resources": {
      "post": {
        "description": "Adds a plan-level resource link. ``title`` is required. ``url`` is optional but must be a valid URL. Requires ``plans:write``.",
        "parameters": [
          {
            "in": "path",
            "name": "plan_id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "title": "Tracing docs",
                "url": "https://example.com/tracing"
              },
