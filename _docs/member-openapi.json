            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "checkpoints": [
                  {
                    "done": true,
                    "id": 123
                  }
                ],
                "deliverables": [
                  {
                    "done": false,
                    "id": 456
                  }
                ],
                "next_steps": [
                  {
                    "done": true,
                    "id": 789
                  }
                ]
              },
              "schema": {
                "properties": {
                  "checkpoints": {
                    "items": {
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "deliverables": {
                    "items": {
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "next_steps": {
                    "items": {
                      "type": "object"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated owned plan progress summary."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
